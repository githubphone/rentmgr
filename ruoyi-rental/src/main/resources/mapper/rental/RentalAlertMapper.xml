<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.rental.mapper.RentalAlertMapper">

    <resultMap type="RentalAlert" id="RentalAlertResult">
        <id     property="id"            column="id"             />
        <result property="accessLogId"   column="access_log_id"  />
        <result property="houseId"       column="house_id"       />
        <result property="alertType"     column="alert_type"     />
        <result property="alertLevel"     column="alert_level"    />
        <result property="photoUrl"       column="photo_url"      />
        <result property="captureTime"    column="capture_time"   />
        <result property="status"        column="status"         />
        <result property="handlerId"     column="handler_id"     />
        <result property="handleTime"     column="handle_time"    />
        <result property="closeRemark"    column="close_remark"   />
        <result property="closeVoucher"  column="close_voucher"  />
        <result property="closeTime"     column="close_time"     />
        <result property="createBy"       column="create_by"      />
        <result property="createTime"     column="create_time"    />
        <result property="updateBy"       column="update_by"      />
        <result property="updateTime"     column="update_time"   />
        <association property="house" javaType="RentalHouse">
            <id     property="id"        column="house_id"       />
            <result property="address"   column="house_address"  />
            <result property="latitude"  column="latitude"       />
            <result property="longitude" column="longitude"      />
            <result property="totalRooms" column="total_rooms"   />
        </association>
    </resultMap>

    <sql id="selectAlertVo">
        select a.id, a.access_log_id, a.house_id, a.alert_type, a.alert_level, a.photo_url,
               a.capture_time, a.status, a.handler_id, a.handle_time, a.close_remark, a.close_voucher,
               a.close_time, a.create_by, a.create_time, a.update_by, a.update_time,
               h.address as house_address, h.latitude, h.longitude, h.total_rooms
        from rental_alerts a
        left join rental_houses h on a.house_id = h.id
    </sql>

    <select id="selectAlertList" parameterType="RentalAlert" resultMap="RentalAlertResult">
        <include refid="selectAlertVo"/>
        <where>
            <if test="houseId != null">and a.house_id = #{houseId}</if>
            <if test="alertType != null and alertType != ''">and a.alert_type = #{alertType}</if>
            <if test="alertLevel != null and alertLevel != ''">and a.alert_level = #{alertLevel}</if>
            <if test="status != null and status != ''">and a.status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND a.create_time &gt;= #{params.beginTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND a.create_time &lt;= #{params.endTime}
            </if>
        </where>
        order by a.create_time desc
    </select>

    <select id="selectAlertById" parameterType="Long" resultMap="RentalAlertResult">
        <include refid="selectAlertVo"/>
        where a.id = #{id}
    </select>

    <insert id="insertAlert" parameterType="RentalAlert" useGeneratedKeys="true" keyProperty="id">
        insert into rental_alerts
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="accessLogId != null">access_log_id,</if>
            <if test="houseId != null">house_id,</if>
            <if test="alertType != null and alertType != ''">alert_type,</if>
            <if test="alertLevel != null and alertLevel != ''">alert_level,</if>
            <if test="photoUrl != null and photoUrl != ''">photo_url,</if>
            <if test="captureTime != null">capture_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="handlerId != null">handler_id,</if>
            <if test="handleTime != null">handle_time,</if>
            <if test="closeRemark != null and closeRemark != ''">close_remark,</if>
            <if test="closeVoucher != null and closeVoucher != ''">close_voucher,</if>
            <if test="closeTime != null">close_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="accessLogId != null">#{accessLogId},</if>
            <if test="houseId != null">#{houseId},</if>
            <if test="alertType != null and alertType != ''">#{alertType},</if>
            <if test="alertLevel != null and alertLevel != ''">#{alertLevel},</if>
            <if test="photoUrl != null and photoUrl != ''">#{photoUrl},</if>
            <if test="captureTime != null">#{captureTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="handlerId != null">#{handlerId},</if>
            <if test="handleTime != null">#{handleTime},</if>
            <if test="closeRemark != null and closeRemark != ''">#{closeRemark},</if>
            <if test="closeVoucher != null and closeVoucher != ''">#{closeVoucher},</if>
            <if test="closeTime != null">#{closeTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            now(),
        </trim>
    </insert>

    <update id="updateAlert" parameterType="RentalAlert">
        update rental_alerts
        <trim prefix="SET" suffixOverrides=",">
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="handlerId != null">handler_id = #{handlerId},</if>
            <if test="handleTime != null">handle_time = #{handleTime},</if>
            <if test="closeRemark != null and closeRemark != ''">close_remark = #{closeRemark},</if>
            <if test="closeVoucher != null and closeVoucher != ''">close_voucher = #{closeVoucher},</if>
            <if test="closeTime != null">close_time = #{closeTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = now(),
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAlertById" parameterType="Long">
        delete from rental_alerts where id = #{id}
    </delete>

    <delete id="deleteAlertByIds" parameterType="Long">
        delete from rental_alerts where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectAlertMapList" parameterType="RentalAlert" resultType="com.ruoyi.rental.domain.vo.AlertMapVO">
        select a.id, a.house_id as houseId, h.address as houseAddress,
               a.alert_type as alertType, a.alert_level as level,
               a.status, a.photo_url as photoUrl,
               h.latitude, h.longitude, h.total_rooms
        from rental_alerts a
        left join rental_houses h on a.house_id = h.id
        where h.latitude is not null and h.longitude is not null
        <if test="status != null and status != ''">
            AND a.status = #{status}
        </if>
        <if test="alertLevel != null and alertLevel != ''">
            AND a.alert_level = #{alertLevel}
        </if>
        order by a.create_time desc
        limit 100
    </select>

</mapper>
