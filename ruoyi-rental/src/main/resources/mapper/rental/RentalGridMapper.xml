<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.rental.mapper.RentalGridMapper">

    <resultMap type="RentalGrid" id="RentalGridResult">
        <id     property="id"               column="id"                  />
        <result property="gridCode"         column="grid_code"          />
        <result property="gridName"         column="grid_name"          />
        <result property="townStreet"       column="town_street"        />
        <result property="villageCommittee" column="village_committee"  />
        <result property="latitude"         column="latitude"           />
        <result property="longitude"        column="longitude"          />
        <result property="remark"           column="remark"             />
        <result property="status"          column="status"             />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="create_time"        />
        <result property="updateBy"         column="update_by"          />
        <result property="updateTime"       column="update_time"        />
    </resultMap>

    <resultMap type="RentalRoleGrid" id="RentalRoleGridResult">
        <id     property="id"               column="id"                  />
        <result property="roleId"           column="role_id"            />
        <result property="gridId"           column="grid_id"            />
        <result property="createBy"         column="create_by"          />
        <result property="createTime"       column="create_time"        />
    </resultMap>

    <sql id="selectGridVo">
        select id, grid_code, grid_name, town_street, village_committee, latitude, longitude,
               remark, status, create_by, create_time, update_by, update_time
        from rental_grids
    </sql>

    <select id="selectGridList" parameterType="RentalGrid" resultMap="RentalGridResult">
        <include refid="selectGridVo"/>
        <where>
            <if test="gridCode != null and gridCode != ''">
                AND grid_code = #{gridCode}
            </if>
            <if test="gridName != null and gridName != ''">
                AND grid_name like concat('%', #{gridName}, '%')
            </if>
            <if test="townStreet != null and townStreet != ''">
                AND town_street = #{townStreet}
            </if>
            <if test="villageCommittee != null and villageCommittee != ''">
                AND village_committee = #{villageCommittee}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectGridById" parameterType="Long" resultMap="RentalGridResult">
        <include refid="selectGridVo"/>
        where id = #{id}
    </select>

    <insert id="insertGrid" parameterType="RentalGrid" useGeneratedKeys="true" keyProperty="id">
        insert into rental_grids
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="gridCode != null and gridCode != ''">grid_code,</if>
            <if test="gridName != null and gridName != ''">grid_name,</if>
            <if test="townStreet != null and townStreet != ''">town_street,</if>
            <if test="villageCommittee != null and villageCommittee != ''">village_committee,</if>
            <if test="latitude != null">latitude,</if>
            <if test="longitude != null">longitude,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="gridCode != null and gridCode != ''">#{gridCode},</if>
            <if test="gridName != null and gridName != ''">#{gridName},</if>
            <if test="townStreet != null and townStreet != ''">#{townStreet},</if>
            <if test="villageCommittee != null and villageCommittee != ''">#{villageCommittee},</if>
            <if test="latitude != null">#{latitude},</if>
            <if test="longitude != null">#{longitude},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            now(),
        </trim>
    </insert>

    <update id="updateGrid" parameterType="RentalGrid">
        update rental_grids
        <trim prefix="SET" suffixOverrides=",">
            <if test="gridCode != null and gridCode != ''">grid_code = #{gridCode},</if>
            <if test="gridName != null and gridName != ''">grid_name = #{gridName},</if>
            <if test="townStreet != null and townStreet != ''">town_street = #{townStreet},</if>
            <if test="villageCommittee != null and villageCommittee != ''">village_committee = #{villageCommittee},</if>
            <if test="latitude != null">latitude = #{latitude},</if>
            <if test="longitude != null">longitude = #{longitude},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = now(),
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteGridById" parameterType="Long">
        delete from rental_grids where id = #{id}
    </delete>

    <delete id="deleteGridByIds" parameterType="Long">
        delete from rental_grids where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectRoleGridList" parameterType="RentalRoleGrid" resultMap="RentalRoleGridResult">
        select id, role_id, grid_id, create_by, create_time
        from rental_role_grid
        <where>
            <if test="roleId != null">
                AND role_id = #{roleId}
            </if>
            <if test="gridId != null">
                AND grid_id = #{gridId}
            </if>
        </where>
    </select>

    <insert id="insertRoleGrid" parameterType="RentalRoleGrid" useGeneratedKeys="true" keyProperty="id">
        insert into rental_role_grid (role_id, grid_id, create_by, create_time)
        values (#{roleId}, #{gridId}, #{createBy}, now())
    </insert>

    <delete id="deleteRoleGridById" parameterType="Long">
        delete from rental_role_grid where id = #{id}
    </delete>

    <delete id="deleteRoleGridByRoleId" parameterType="Long">
        delete from rental_role_grid where role_id = #{roleId}
    </delete>

    <select id="selectGridIdByRoleId" parameterType="Long" resultType="Long">
        select grid_id from rental_role_grid where role_id = #{roleId} limit 1
    </select>

    <select id="selectGridMemberUserIds" parameterType="Long" resultType="Long">
        select distinct ur.user_id
        from sys_user_role ur
        inner join rental_role_grid rg on ur.role_id = rg.role_id
        where rg.grid_id = #{gridId}
    </select>

</mapper>
