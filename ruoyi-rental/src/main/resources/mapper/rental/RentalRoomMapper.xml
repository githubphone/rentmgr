<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.rental.mapper.RentalRoomMapper">

    <resultMap type="com.ruoyi.rental.domain.RentalRoom" id="RentalRoomResult">
        <result property="id" column="id"/>
        <result property="houseId" column="house_id"/>
        <result property="roomNo" column="room_no"/>
        <result property="floor" column="floor"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <association property="house" javaType="com.ruoyi.rental.domain.RentalHouse">
            <id property="id" column="house_id"/>
            <result property="address" column="house_address"/>
        </association>
    </resultMap>

    <sql id="selectRoomVo">
        select r.id, r.house_id, r.room_no, r.floor, r.status, r.remark,
               r.create_by, r.create_time, r.update_by, r.update_time,
               h.address as house_address
        from rental_room r
        left join rental_houses h on r.house_id = h.id
    </sql>

    <select id="selectRoomList" parameterType="com.ruoyi.rental.domain.RentalRoom" resultMap="RentalRoomResult">
        <include refid="selectRoomVo"/>
        <where>
            <if test="houseId != null">
                and r.house_id = #{houseId}
            </if>
            <if test="roomNo != null and roomNo != ''">
                and r.room_no like concat('%', #{roomNo}, '%')
            </if>
            <if test="status != null and status != ''">
                and r.status = #{status}
            </if>
        </where>
        order by r.create_time desc
    </select>

    <select id="selectRoomById" parameterType="Long" resultMap="RentalRoomResult">
        <include refid="selectRoomVo"/>
        where r.id = #{id}
    </select>

    <select id="selectRoomByHouseId" parameterType="Long" resultMap="RentalRoomResult">
        <include refid="selectRoomVo"/>
        where r.house_id = #{houseId}
        order by r.room_no
    </select>

    <insert id="insertRoom" parameterType="com.ruoyi.rental.domain.RentalRoom" useGeneratedKeys="true" keyProperty="id">
        insert into rental_room
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="houseId != null">house_id,</if>
            <if test="roomNo != null and roomNo != ''">room_no,</if>
            <if test="floor != null and floor != ''">floor,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="houseId != null">#{houseId},</if>
            <if test="roomNo != null and roomNo != ''">#{roomNo},</if>
            <if test="floor != null and floor != ''">#{floor},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            now(),
        </trim>
    </insert>

    <update id="updateRoom" parameterType="com.ruoyi.rental.domain.RentalRoom">
        update rental_room
        <trim prefix="SET" suffixOverrides=",">
            <if test="roomNo != null and roomNo != ''">room_no = #{roomNo},</if>
            <if test="floor != null and floor != ''">floor = #{floor},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = now(),
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteRoomById" parameterType="Long">
        delete from rental_room where id = #{id}
    </delete>

    <delete id="deleteRoomByIds" parameterType="Long">
        delete from rental_room where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
