<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.rental.mapper.RentalResidentMapper">

    <resultMap type="RentalResident" id="RentalResidentResult">
        <id     property="id"           column="id"             />
        <result property="houseId"      column="house_id"       />
        <result property="roomId"       column="room_id"        />
        <result property="name"         column="name"           />
        <result property="idCard"       column="id_card"        />
        <result property="phone"         column="phone"          />
        <result property="faceId"       column="face_id"        />
        <result property="residentType" column="resident_type"  />
        <result property="checkInDate"  column="check_in_date"  />
        <result property="checkOutDate" column="check_out_date" />
        <result property="status"       column="status"         />
        <result property="createBy"     column="create_by"      />
        <result property="createTime"   column="create_time"    />
        <result property="updateBy"     column="update_by"      />
        <result property="updateTime"   column="update_time"    />
        <result property="houseAddress" column="house_address"  />
        <result property="roomNo"       column="room_no"        />
    </resultMap>

    <sql id="selectResidentVo">
        SELECT r.id, r.house_id, r.room_id, r.name, r.id_card, r.phone, r.face_id,
               r.resident_type, r.check_in_date, r.check_out_date, r.status,
               r.create_by, r.create_time, r.update_by, r.update_time,
               h.address AS house_address, rm.room_no
        FROM rental_residents r
        LEFT JOIN rental_houses h ON r.house_id = h.id
        LEFT JOIN rental_room rm ON r.room_id = rm.id
    </sql>

    <select id="selectResidentList" parameterType="RentalResident" resultMap="RentalResidentResult">
        <include refid="selectResidentVo"/>
        <where>
            <if test="houseId != null">and house_id = #{houseId}</if>
            <if test="roomId != null">and room_id = #{roomId}</if>
            <if test="name != null and name != ''">and name like concat('%', #{name}, '%')</if>
            <if test="idCard != null and idCard != ''">and id_card = #{idCard}</if>
            <if test="phone != null and phone != ''">and phone = #{phone}</if>
            <if test="residentType != null and residentType != ''">and resident_type = #{residentType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectResidentById" parameterType="Long" resultMap="RentalResidentResult">
        <include refid="selectResidentVo"/>
        where id = #{id}
    </select>

    <insert id="insertResident" parameterType="RentalResident" useGeneratedKeys="true" keyProperty="id">
        insert into rental_residents
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="houseId != null">house_id,</if>
            <if test="roomId != null">room_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="idCard != null and idCard != ''">id_card,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="faceId != null and faceId != ''">face_id,</if>
            <if test="residentType != null and residentType != ''">resident_type,</if>
            <if test="checkInDate != null">check_in_date,</if>
            <if test="checkOutDate != null">check_out_date,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="houseId != null">#{houseId},</if>
            <if test="roomId != null">#{roomId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="idCard != null and idCard != ''">#{idCard},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="faceId != null and faceId != ''">#{faceId},</if>
            <if test="residentType != null and residentType != ''">#{residentType},</if>
            <if test="checkInDate != null">#{checkInDate},</if>
            <if test="checkOutDate != null">#{checkOutDate},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            now(),
        </trim>
    </insert>

    <update id="updateResident" parameterType="RentalResident">
        update rental_residents
        <trim prefix="SET" suffixOverrides=",">
            <if test="houseId != null">house_id = #{houseId},</if>
            <if test="roomId != null">room_id = #{roomId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="idCard != null and idCard != ''">id_card = #{idCard},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="faceId != null and faceId != ''">face_id = #{faceId},</if>
            <if test="residentType != null and residentType != ''">resident_type = #{residentType},</if>
            <if test="checkInDate != null">check_in_date = #{checkInDate},</if>
            <if test="checkOutDate != null">check_out_date = #{checkOutDate},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = now(),
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteResidentById" parameterType="Long">
        delete from rental_residents where id = #{id}
    </delete>

    <delete id="deleteResidentByIds" parameterType="Long">
        delete from rental_residents where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
